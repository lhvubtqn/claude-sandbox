global:
  container:
    image: claude-sandbox
    security_opt:
      - seccomp=unconfined
    extra_hosts:
      - host.docker.internal:host-gateway
    volumes:
      # Persistent storage for Claude's configuration, credentials, and caches
      - claude-config:/home/claude/.claude
      - cargo-registry:/home/claude/.cargo/registry
      - cargo-git:/home/claude/.cargo/git
      - rustup-downloads:/home/claude/.rustup/downloads
      - npm-cache:/home/claude/.npm
      - npm-globals:/home/claude/.npm-globals
      - pipx:/home/claude/.pipx
      - solana-config:/home/claude/.config/solana
      - vscode-server:/home/claude/.vscode-server

      # Mount the skills and rules directories from the host for easy development
      - ${WORKDIR}/skills:/home/claude/.claude/skills:ro
      - ${WORKDIR}/rules:/home/claude/.claude/rules:ro

projects:
  ${WORKDIR}:
    # GUI display backend for this project. `wslg` wires up the WSLg X11/Wayland
    # sockets + display env and installs the needed runtime libs on first start
    # (WSL hosts only). Default `none` keeps the sandbox headless and lean.
    # Toggle with `claude-sandbox ui <mode>`; restart to apply.
    ui_mode: none
    # Per-project container overrides (merged with global). Both docker-compose
    # env forms work (map or "- KEY=value" list); values support ${WORKDIR},
    # ${HOME}, and leading ~/. Volumes can also use `claude-sandbox mounts add`.
    # container:
    #   volumes:
    #     - /host/path:/container/path
    #   environment:
    #     KEY: value
    #   network: my-net   # join an existing Docker network (docker network create my-net)
    git_auth:
      type: ssh
      path: ${HOME}/.ssh/id_ed25519
      prefer_ssh: true
      identity:
        name: Your Name
        email: your.email@example.com
